# ─── Firebase Configuration ────────────────────────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Create a new project
# 3. Add a Web App → copy the firebaseConfig values below
# 4. Enable Firestore Database (Start in test mode)
# 5. Enable Storage (Start in test mode)
# ───────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Admin Panel ───────────────────────────────────────────────────
# Password to access the /admin panel. Keep this secret!
VITE_ADMIN_PASSWORD=ShriSwastik@Admin2024

# ─── WhatsApp ──────────────────────────────────────────────────────
# Phone number with country code (no + or spaces)
# Example: 919876543210 for +91 98765 43210
VITE_WHATSAPP_NUMBER=919999999999
